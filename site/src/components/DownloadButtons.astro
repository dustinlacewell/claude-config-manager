---
import pkg from "../../../package.json";

interface Props {
  size?: "md" | "lg";
  align?: "start" | "center";
}

const { size = "md", align = "start" } = Astro.props;

// Injected at build time by `.github/workflows/site.yml`. PUBLIC_LATEST_TAG is
// the v-prefixed tag of the latest published release (e.g. "v0.1.0"); the
// site's bundled package.json is the local-dev fallback.
const tag = import.meta.env.PUBLIC_LATEST_TAG ?? `v${pkg.version}`;
const version = tag.replace(/^v/, "");
const base =
  import.meta.env.PUBLIC_RELEASES_BASE ??
  "https://github.com/dustinlacewell/claude-config-manager/releases";
const dl = (file: string) => `${base}/download/${tag}/${file}`;

const platforms = [
  {
    name: "macOS",
    href: dl(`ccm_${version}_aarch64.dmg`),
    sub: "Apple Silicon · .dmg",
    icon: `<path d="M17.05 12.74c-.02-2.07 1.69-3.07 1.77-3.12-.97-1.41-2.47-1.6-3-1.62-1.27-.13-2.49.75-3.14.75-.66 0-1.65-.73-2.72-.71-1.4.02-2.69.81-3.41 2.07-1.45 2.52-.37 6.25 1.05 8.3.69 1 1.52 2.13 2.59 2.09 1.04-.04 1.43-.67 2.69-.67 1.25 0 1.61.67 2.72.65 1.12-.02 1.84-1.02 2.53-2.03.8-1.16 1.13-2.29 1.15-2.35-.03-.01-2.2-.84-2.23-3.36zM15.03 6.7c.57-.7.96-1.66.86-2.62-.83.04-1.84.55-2.43 1.24-.53.62-.99 1.6-.87 2.55.93.07 1.87-.48 2.44-1.17z" fill="currentColor"/>`,
  },
  {
    name: "Windows",
    href: dl(`ccm_${version}_x64-setup.exe`),
    sub: "x64 · installer",
    icon: `<path d="M3 5.5L10.5 4.5v7H3V5.5zM3 12.5h7.5v7L3 18.5v-6zM11.5 4.3L21 3v9h-9.5V4.3zM11.5 12.5H21V21l-9.5-1.2v-7.3z" fill="currentColor"/>`,
  },
  {
    name: "Linux",
    href: dl(`ccm_${version}_amd64.AppImage`),
    sub: "x64 · AppImage",
    icon: `<path d="M12 2c-1.66 0-3 1.79-3 4 0 1.5.5 2.5 1 3 0 0-.5.5-1 1.5s-1.5 3-2 4-1 2-1 3c0 .5.25 1 1 1.5S8 20 9 20.5s2 1 3 1 2-.5 3-1 1.25-1 2-1.5 1-1 1-1.5c0-1-.5-2-1-3s-1.5-3-2-4-1-1.5-1-1.5c.5-.5 1-1.5 1-3 0-2.21-1.34-4-3-4zm-1.5 5.5c.3 0 .5.3.5.5s-.2.5-.5.5-.5-.2-.5-.5.2-.5.5-.5zm3 0c.3 0 .5.3.5.5s-.2.5-.5.5-.5-.2-.5-.5.2-.5.5-.5z" fill="currentColor"/>`,
  },
];

const wrapperClass = align === "center" ? "justify-center" : "justify-start";
const padding = size === "lg" ? "px-5 py-4" : "px-4 py-3";
const iconSize = size === "lg" ? "h-6 w-6" : "h-5 w-5";
const otherAlign = align === "center" ? "text-center" : "text-left";
---

<div>
  <div class={`flex flex-wrap items-center gap-3 ${wrapperClass}`}>
    {platforms.map(({ name, href, sub, icon }) => (
      <a
        href={href}
        class:list={[
          "group inline-flex items-center gap-3 rounded-xl border transition-all",
          padding,
          "bg-ink-900/50 text-ink-100 border-hairline hover:bg-ink-800/70 hover:border-ink-500",
        ]}
      >
        <svg viewBox="0 0 24 24" fill="none" class={iconSize} set:html={icon} />
        <div class="flex flex-col items-start leading-tight">
          <span class="text-[11px] opacity-70 font-medium">Download for</span>
          <span class={size === "lg" ? "text-base font-semibold" : "text-sm font-semibold"}>{name}</span>
          <span class="text-[10px] font-mono opacity-60 mt-0.5">{sub}</span>
        </div>
      </a>
    ))}
  </div>
  <p class={`mt-3 text-xs text-ink-500 ${otherAlign}`}>
    Other builds (Intel Mac, .msi, .deb, .rpm) on the
    <a href={`${base}/tag/${tag}`} class="underline hover:text-ink-300">release page</a>.
  </p>
</div>
