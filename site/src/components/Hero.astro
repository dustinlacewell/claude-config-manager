---
import DownloadButtons from "./DownloadButtons.astro";
import pkg from "../../../package.json";

const version = `v${pkg.version}`;
---

<section class="relative overflow-hidden">
  <div class="absolute inset-0 bg-mesh pointer-events-none"></div>
  <div class="absolute inset-0 bg-grid pointer-events-none"></div>

  <div class="relative max-w-6xl mx-auto px-6 pt-10 pb-24 md:pt-14 md:pb-32">
    <h1
      class="animate-fade-up delay-100 text-5xl md:text-7xl font-bold tracking-tight leading-[1.02] text-balance"
    >
      Every Claude config.
      <br />
      <span class="bg-gradient-to-r from-accent via-accent-soft to-accent bg-clip-text text-transparent">
        One place.
      </span>
    </h1>

    <p
      class="animate-fade-up delay-200 mt-8 max-w-2xl text-lg md:text-xl text-ink-300 text-pretty leading-relaxed"
    >
      CCM is a native desktop app for managing Claude Code — agents, commands,
      skills, memory, rules, hooks, MCP servers, and more — across every
      project you touch.
    </p>

    <div class="animate-fade-up delay-300 mt-10">
      <p class="mb-3 text-sm text-ink-400">
        Latest version: <span class="font-mono text-ink-200">{pkg.version}</span>
      </p>
      <DownloadButtons />
    </div>

    <div class="animate-fade-up delay-400 mt-12 relative">
      <div class="absolute -inset-x-8 -inset-y-4 bg-gradient-to-b from-accent/20 via-transparent to-transparent blur-3xl opacity-50 pointer-events-none"></div>

      <div class="relative rounded-xl border border-hairline bg-ink-950 overflow-hidden shadow-glow">
        <div class="flex items-center gap-1.5 px-4 py-3 border-b border-hairline bg-ink-900/80">
          <span class="h-3 w-3 rounded-full bg-ink-700"></span>
          <span class="h-3 w-3 rounded-full bg-ink-700"></span>
          <span class="h-3 w-3 rounded-full bg-ink-700"></span>
          <span class="ml-3 text-xs font-mono text-ink-400">CCM — Claude Code Manager</span>
          <span class="ml-auto text-[10px] font-mono text-ink-500">live demo · {version}</span>
        </div>

        <div class="relative h-[520px] md:h-[640px] bg-ink-950">
          <div
            id="demo-placeholder"
            class="absolute inset-0 flex items-center justify-center bg-gradient-to-br from-ink-900 to-ink-950 transition-opacity duration-500"
          >
            <div class="absolute inset-0 bg-grid opacity-60"></div>
            <div class="relative flex items-center gap-3 px-5 py-2.5 rounded-full border border-hairline bg-ink-900/80 backdrop-blur">
              <span class="h-1.5 w-1.5 rounded-full bg-accent animate-pulse"></span>
              <span class="font-mono text-[12px] text-ink-300 uppercase tracking-widest">Loading demo…</span>
            </div>
          </div>
          <iframe
            id="demo-frame"
            data-src="/demo/index.html"
            title="CCM live demo"
            class="absolute inset-0 w-full h-full border-0 opacity-0 transition-opacity duration-500"
            allow="clipboard-read; clipboard-write"
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Lazy-load the demo iframe: the standalone app is ~2 MB of JS + Shiki
  // chunks on demand. Only start fetching once the hero actually enters
  // (or nears) the viewport — on most screens this fires immediately
  // anyway, but it saves the payload for visitors who bounce instantly.
  const frame = document.getElementById('demo-frame') as HTMLIFrameElement | null
  const placeholder = document.getElementById('demo-placeholder') as HTMLDivElement | null

  if (frame && placeholder) {
    const load = () => {
      if (frame.src) return
      const target = frame.dataset.src
      if (!target) return
      frame.addEventListener(
        'load',
        () => {
          frame.style.opacity = '1'
          placeholder.style.opacity = '0'
          window.setTimeout(() => placeholder.remove(), 500)
        },
        { once: true },
      )
      frame.src = target
    }

    if ('IntersectionObserver' in window) {
      const obs = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              load()
              obs.disconnect()
              return
            }
          }
        },
        { rootMargin: '200px' },
      )
      obs.observe(frame)
    } else {
      load()
    }
  }
</script>
